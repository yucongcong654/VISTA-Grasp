# Copy this file to `.env` in the repository root and adjust values for your setup.
# Frontend variables must use the VITE_ prefix because Vite exposes only VITE_* to browser code.

# Frontend dev server
VITE_TELEOP_FRONTEND_HOST=0.0.0.0
VITE_TELEOP_FRONTEND_PORT=5173

# Browser -> PC backend WebSocket/WebRTC signaling
TELEOP_SERVER_HOST=localhost
TELEOP_SERVER_PORT=5174
VITE_TELEOP_WS_HOST=
VITE_TELEOP_WS_PORT=5174
VITE_TELEOP_WS_PROTOCOL=

# PC backend -> robot bridge
TELEOP_ROBOT_HOST=localhost
TELEOP_ROBOT_PORT=5175
TELEOP_ROBOT_BRIDGE_HOST=localhost

# Main backend loop
TELEOP_CONTROL_FPS=30
TELEOP_MODE=controller_mode
TELEOP_CONDA_ENV=teleop
TELEOP_BACKEND_START_DELAY=5
TELEOP_DUMMY_TEST=false

# XR tracking configuration
TELEOP_HEAD_TRACK_FPS=30
TELEOP_HEAD_POSITION_THRESHOLD=0.0001
TELEOP_HEAD_ROTATION_THRESHOLD=0.0001
TELEOP_CONTROLLER_TRACK_FPS=50
TELEOP_HAND_TRACK_FPS=50

# WebRTC video configuration
TELEOP_VIDEO_STREAM_IDS=camera0,camera1
TELEOP_VIDEO_WIDTH=2
TELEOP_VIDEO_HEIGHT=0.9
TELEOP_VIDEO_DISTANCE=2
TELEOP_VIDEO_NUM_SMALL=1

# Robot camera ROS topics
TELEOP_CAMERA0_TOPIC=/camera_0/color/image_raw
TELEOP_CAMERA1_TOPIC=/camera_1/color/image_raw

# Robot control ROS topics
TELEOP_HEAD_CONTROL_TOPIC=/servo_control/move
TELEOP_HEAD_CONTROL_YAW_PITCH_TOPIC=/servo_control/move_double
TELEOP_LIFT_CONTROL_TOPIC=/l_arm/rm_driver/Lift_SetHeight
TELEOP_LIFT_SPEED_CONTROL_TOPIC=/l_arm/rm_driver/Lift_SetSpeed
TELEOP_LEFT_ARM_CONTROL_TOPIC=/l_arm/rm_driver/JointPos
TELEOP_RIGHT_ARM_CONTROL_TOPIC=/r_arm/rm_driver/JointPos
TELEOP_LEFT_HAND_CONTROL_TOPIC=/rx_gripper_control
TELEOP_RIGHT_GRIPPER_CONTROL_TOPIC=/gripper_control
TELEOP_UNDERPAN_CONTROL_TOPIC=/base_cmd_vel
TELEOP_LEFT_ARM_STATE_TOPIC=/l_arm/joint_states
TELEOP_RIGHT_ARM_STATE_TOPIC=/r_arm/joint_states

# Robot SSH/script defaults used by run/rob.sh
TELEOP_ROBOT_SSH_USER=rm
TELEOP_ROBOT_SSH_HOST=192.168.31.247
TELEOP_ROBOT_WORKDIR='~/catkin_ws'
TELEOP_ROBOT_SETUP=devel/setup.zsh
TELEOP_ROBOT_LAUNCH_PACKAGE=dual_arm_robot_demo
TELEOP_ROBOT_LAUNCH_FILE=teleop_control_start.launch
TELEOP_ROBOT_BRIDGE_SCRIPT=src/dual_arm_robot_demo/scripts/teleop_ros_bridge.py
TELEOP_ROBOT_NO_HEAD=false

# VR/ADB helper values for documentation or your own scripts
TELEOP_VR_ADB_HOST=192.168.31.124
TELEOP_VR_ADB_PORT=5555
